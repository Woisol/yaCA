    {
      "type": "node",
      "request": "launch",
      "name": "cli (tsx)",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "runtimeExecutable": "${workspaceFolder}\\node_modules\\.bin\\tsx.cmd",
      "args": [
        "${workspaceFolder}\\apps\\index.ts"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "cli",
      // 默认值 internalConsole 不支持读取输入
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "preLaunchTask": "npm: build",
      "program": "${workspaceFolder}\\dist\\index.js",
      "outFiles": [
        "${workspaceFolder}/**/*.js"
      ],
      "args": []
    },
  ]
