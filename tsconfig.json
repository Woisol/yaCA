{
  "compilerOptions": {
    // "baseUrl": ".", // deprecated
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "sourceMap": true,
    "types": [
      "node"
    ],
    "declaration": true,
    "paths": {
      // "@yaca/cli/screens/repl-ui.js": [
      //   "./apps/cli/src/screens/repl-ui.tsx"
      // ],
      "@yaca/cli/*": [
        "./apps/cli/src/*"
      ],
      "@yaca/web/*": [
        "./apps/web/src/*"
      ],
      "@woisol-g/yaca-web/server.js": [
        "./apps/yaca-web/src/server.ts"
      ],
      "@woisol-g/yaca-web/server/prompt.js": [
        "./apps/yaca-web/src/server/prompt.ts"
      ],
      "@woisol-g/yaca-web/*": [
        "./apps/yaca-web/src/*"
      ],
      "@woisol-g/llm-html": [
        "./packages/llm-html/src/index.ts"
      ],
      "@woisol-g/llm-html/highlight": [
        "./packages/llm-html/src/highlight.ts"
      ],
      "@woisol-g/yaca/web-runtime.js": [
        "./apps/index.ts"
      ],
      "@yaca/agent-core": [
        "./packages/agent-core/src/index.ts"
      ],
      "@yaca/agent-core/*": [
        "./packages/agent-core/src/*"
      ],
      "@yaca/agent-tools": [
        "./packages/agent-tools/src/index.ts"
      ],
      "@yaca/agent-tools/*": [
        "./packages/agent-tools/src/*"
      ],
      "@yaca/types": [
        "./packages/shared/types/index.ts"
      ],
      "@yaca/types/*": [
        "./packages/shared/types/*"
      ],
      "@yaca/ui/*": [
        "./packages/shared/ui/src/*"
      ],
      "@yaca/ui": [
        "./packages/shared/ui/src/index.ts"
      ],
      "@yaca/utils/*": [
        "./packages/utils/*"
      ]
    }
  },
  "include": [
    "test/**/*.ts",
    "apps/**/*.ts",
    // 记得加 tsx 啊啊，不加不解析 @path！
    "apps/**/*.tsx",
    "packages/**/*.ts",
  ],
}
