{
  "name": "@woisol-g/yaca",
  "version": "1.4.0",
  "description": "Yet another Coding Agent.",
  "type": "module",
  "bin": {
    "yaca": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./web-runtime.js": "./dist/web-runtime.js"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run typecheck && node --import tsx --test test/*.test.ts",
    "dev:cli": "tsx apps/index.ts",
    "dev:web": "tsx apps/index.ts --serve",
    "build:watch": "cd apps/yaca-web; vp build --watch",
    "start:cli": "node dist/index.js",
    "start:web": "node dist/index.js",
    "prepare": "husky"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "husky": "^9.1.7",
    "ink": "^7.0.2",
    "ink-text-input": "^6.0.0",
    "openai": "^6.36.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/shared/*"
  ],
  "packageManager": "pnpm@11.0.9"
}
